#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// total rooms in hotel
#define TOTAL_ROOMS 10

// admin pass
#define ADMIN_PASSWORD "admin123"

// file names
#define ROOMS_FILE "rooms.txt"
#define BOOKINGS_FILE "bookings.txt"

// room structure
struct Room {
    int number;
    char type[10];   // single double suite
    float price;
    int is_booked;   // 0=free 1=booked
};

// booking structure
struct Booking {
    int id;
    int room_number;
    char name[50];
    char phone[15];
    int nights;
    float total;
    int active;  // 1=active 0=cancelled
};

// global arrays
struct Room rooms[TOTAL_ROOMS];
struct Booking bookings[100];
int num_rooms = 0;
int num_bookings = 0;

// function declarations
void setup_rooms();
void save_rooms();
void load_rooms();
void save_bookings();
void load_bookings();

void show_menu();
void check_available();
void book_room();
void cancel_booking();
void view_booking();

void admin_menu();
void admin_view_all();
void admin_update_price();
void admin_view_bookings();

void pressEnter();

// main function
int main()
{
    int ch;

    // load data from files
    load_rooms();
    load_bookings();

    // if first time, make default rooms
    if (num_rooms == 0) {
        setup_rooms();
        save_rooms();
        printf("First time setup done. Rooms created.\n");
        pressEnter();
    }

    while (1) {
        system("cls || clear");

        printf("\n");
        printf("  ================================\n");
        printf("      SUNSHINE HOTEL SYSTEM      \n");
        printf("  ================================\n");
        printf("  1. Check Available Rooms\n");
        printf("  2. Book a Room\n");
        printf("  3. Cancel Booking\n");
        printf("  4. View My Booking\n");
        printf("  5. Admin Panel\n");
        printf("  6. Exit\n");
        printf("  ================================\n");
        printf("  Enter choice: ");
        scanf("%d", &ch);

        if (ch == 1)
            check_available();
        else if (ch == 2) {
            book_room();
            save_rooms();
            save_bookings();
        }
        else if (ch == 3) {
            cancel_booking();
            save_rooms();
            save_bookings();
        }
        else if (ch == 4)
            view_booking();
        else if (ch == 5)
            admin_menu();
        else if (ch == 6) {
            printf("\n  Bye bye!\n\n");
            break;
        }
        else {
            printf("  Invalid choice.\n");
            pressEnter();
        }
    }

    return 0;
}
